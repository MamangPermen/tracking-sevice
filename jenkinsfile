pipeline {
    agent any

    environment {
        IMAGE_NAME = 'tracking-service'
        IMAGE_TAG = "v${env.BUILD_NUMBER}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Prepare') {
            steps {
                echo "Downloading dependencies..."
                bat 'go mod download'
            }
        }

        stage('Unit Test') {
            steps {
                // Menggunakan ./... agar mengetes seluruh package secara rekursif
                bat 'go test ./... -v'
            }
        }

        stage('Lint/Vet') {
            steps {
                bat 'go vet ./...'
            }
        }

        stage('Build Image') {
            steps {
                echo "Building Docker image with tags: ${IMAGE_TAG} and latest"
                // Build dengan tag versi dan juga tag latest untuk sinkronisasi dengan k8s deployment
                bat "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} -t ${IMAGE_NAME}:latest ."
            }
        }

        stage('Functional Test') {
            steps {
                // Menjalankan test dengan build tag functional
                bat 'go test -tags=functional ./internal/service -v'
            }
        }

        stage('Push Image') {
            steps {
                echo "Pushing image to container registry..."
                // bat "docker push ${IMAGE_NAME}:${IMAGE_TAG}"
                // bat "docker push ${IMAGE_NAME}:latest"
            }
        }

        stage('Deploy K8s') {
            steps {
                echo "Applying Kubernetes manifests..."
                // bat 'kubectl apply -f k8s/'
                
                // Tips: Jika ingin update image spesifik ke versi build:
                // bat "kubectl set image deployment/tracking-service tracking-service=${IMAGE_NAME}:${IMAGE_TAG}"
            }
        }

        stage('Verify') {
            steps {
                echo "Verifying deployment status..."
                // Menggunakan rollout status lebih akurat daripada sekadar get pods
                // bat 'kubectl rollout status deployment/tracking-service'
            }
        }
    }
}